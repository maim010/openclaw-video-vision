  "repository": {
    "type": "git",
    "url": "git+https://github.com/maim010/openclaw-video-vision.git"
  },
  "bugs": {
    "url": "https://github.com/maim010/openclaw-video-vision/issues"
  },
  "homepage": "https://github.com/maim010/openclaw-video-vision#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "playwright-core": "^1.42.0"
  }
}
