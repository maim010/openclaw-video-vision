{
  "name": "openclaw-video-vision",
  "version": "1.0.0",
  "description": "OpenClaw skill — crawl YouTube, Bilibili & other video platforms, extract key frames with FFmpeg, and summarize content using vision AI models",
  "main": "src/index.js",
  "bin": {
    "video-vision": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
